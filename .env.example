# ============================================================
# financeHub 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 채워 넣으세요.
# .env 는 .gitignore 에 포함되어 있어 git에 올라가지 않습니다.
# ============================================================

# --- PostgreSQL (docker-compose + Spring DataSource) ---
POSTGRES_USER=financeuser
POSTGRES_PASSWORD=여기에_실제_비밀번호
POSTGRES_DB=financehub

# --- Spring DataSource ---
DB_HOST=jdbc:postgresql://localhost:5432/financehub
DB_USERNAME=financeuser
DB_PASSWORD=여기에_실제_비밀번호

# --- JWT ---
JWT_SECRET=여기에_랜덤_시크릿_키_최소_32자

# --- Jasypt (application.yml 내 암호화된 값 복호화 키) ---
JASYPT_ENCRYPTOR_PASSWORD=여기에_랜덤_패스워드

# --- KIS OpenAPI ---
KIS_APP_KEY=여기에_KIS_앱키
KIS_APP_SECRET=여기에_KIS_앱시크릿
